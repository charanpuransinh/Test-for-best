{
  "version": 2,
  "builds": [
    {
      "src": "gemini_backend.py",
      "use": "@vercel/python"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/analyze",
      "dest": "gemini_backend.py"
    },
    {
      "src": "/patterns",
      "dest": "gemini_backend.py"
    },
    {
      "src": "/",
      "dest": "index.html"
    },
    {
      "src": "/(.*\\.html)",
      "dest": "/$1"
    }
  ]
}
